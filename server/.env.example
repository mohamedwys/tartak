# ---- Server ----
PORT=5000
NODE_ENV=development
# Comma-separated allowlist of browser origins. Requests from any other
# origin are rejected with 403. Add every domain you'll serve from
# (localhost for dev, staging URL, production URL).
CORS_ORIGIN=http://localhost:4200

# Values from Supabase Dashboard → Project Settings → API.
# Do NOT commit real keys here — put them in a local, gitignored `.env`
# file and in your host's environment variables panel (Render / Vercel / etc).
#
# SUPABASE_SERVICE_ROLE_KEY must be the `service_role secret` — a long
# eyJhbGciOi... JWT visible only to the project owner. It bypasses RLS and
# MUST stay server-side. Do NOT paste a publishable (`sb_publishable_...`)
# key here; that's the anon key and it does not grant the permissions this
# backend needs.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_JWT
SUPABASE_ANON_KEY=REPLACE_WITH_ANON_OR_PUBLISHABLE_KEY   # optional; unused unless you call Supabase from the Angular app
>>>>>>> 5b4394fc3f1bc3e83a537330ba0fe999812bca43

# ---- Supabase Storage (for /api/upload) ----
SUPABASE_STORAGE_BUCKET=product-images

# ---- Auth (JWTs issued by this backend) ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Email verification / password reset links (used in token emails) ----
APP_URL=http://localhost:4200

# ---- One-off data migration from MongoDB (optional) ----
MONGO_URI=
MONGO_DB_NAME=
