# ---- Server ----
PORT=5000
NODE_ENV=development
# Comma-separated allowlist of browser origins. Requests from any other
# origin are rejected with 403. Add every domain you'll serve from
# (localhost for dev, staging URL, production URL).
CORS_ORIGIN=http://localhost:4200

# ---- Supabase ----
# From Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME   # server-side only, NEVER expose to browser
SUPABASE_ANON_KEY=REPLACE_ME           # optional; only used if you add client-side SDK access

# ---- Supabase Storage (for /api/upload) ----
SUPABASE_STORAGE_BUCKET=product-images

# ---- Auth (JWTs issued by this backend) ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Email verification / password reset links (used in token emails) ----
APP_URL=http://localhost:4200

# ---- One-off data migration from MongoDB (optional) ----
MONGO_URI=
MONGO_DB_NAME=
